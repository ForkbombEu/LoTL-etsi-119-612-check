{
  "name": "we-build-tl-audit",
  "version": "0.1.0",
  "description": "Audit Trusted Lists referenced by a WE BUILD WP4 LoTL JSON file.",
  "type": "module",
  "bin": {
    "we-build-tl-audit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/api/assets && cp src/api/assets/*.svg src/api/assets/*.css dist/api/assets/",
    "test": "vitest run",
    "test:ts119602-coverage": "vitest run test/ts119602ImplementedCoverage.test.ts test/ts119602Coverage.test.ts",
    "test:ts119612-coverage": "vitest run test/ts119612ImplementedCoverage.test.ts test/ts119612Coverage.test.ts",
    "api": "node dist/api/server.js",
    "dev:api": "tsx src/api/server.ts",
    "reference-smoke": "scripts/optional/reference-source-smoke.sh",
    "eudi-ri-tlp-fixture-readiness": "scripts/optional/eudi-ri-tlp-fixture-readiness.sh",
    "reference-smoke-run": "scripts/optional/run-reference-smoke.sh",
    "package-reference-smoke": "scripts/optional/package-reference-smoke.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@xmldom/xmldom": "^0.9.8",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "xpath": "^0.0.34",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
