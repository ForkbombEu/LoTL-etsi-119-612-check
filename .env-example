# API bind address.
# Use 127.0.0.1 for local-only access, 0.0.0.0 for container/LAN binding.
HOST=127.0.0.1
PORT=3000

# Optional externally visible base URL used in OpenAPI servers[].
# If empty, /openapi.yaml and /openapi.json derive this from the request Host header.
# PUBLIC_BASE_URL=http://127.0.0.1:3000

# CORS_ORIGIN=* allows Stoplight Try-It from the served docs page and local browsers.
# Use comma-separated origins to restrict, e.g. http://127.0.0.1:3000,http://localhost:3000
CORS_ORIGIN=*

# Default audit options used when request bodies omit options.
AUDIT_CONCURRENCY=4
AUDIT_TIMEOUT_MS=15000
AUDIT_STRICT=false
AUDIT_INCLUDE_JSON_LOTE_CHECKS=false
AUDIT_FETCH=true
